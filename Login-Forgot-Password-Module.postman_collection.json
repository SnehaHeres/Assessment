{
	"info": {
		"_postman_id": "8c5b3670-8b1e-4cb8-9f1e-e27bf88b39fb",
		"name": "MERN Login & Forgot Password Module",
		"description": "API collection for registering, logging in, retrieving authenticated profiles, requesting reset password tokens, and resetting passwords.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data && jsonData.data.token) {",
									"    pm.collectionVariables.set(\"authToken\", jsonData.data.token);",
									"    pm.visualizer.set('Account created successfully! Token saved to variables.');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Jane Doe\",\n    \"email\": \"jane@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"register"
							]
						},
						"description": "Registers a new user on the platform. Returns a JWT auth token upon successful registration and saves it to collection variables automatically."
					},
					"response": []
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data && jsonData.data.token) {",
									"    pm.collectionVariables.set(\"authToken\", jsonData.data.token);",
									"    pm.visualizer.set('Logged in successfully! Token saved to variables.');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"jane@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"login"
							]
						},
						"description": "Authenticates user credentials. Returns user details and a JWT token, which is stored automatically in `authToken` variable."
					},
					"response": []
				},
				{
					"name": "Forgot Password",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.devToken) {",
									"    pm.collectionVariables.set(\"resetToken\", jsonData.devToken);",
									"    pm.visualizer.set('Reset token captured from Dev Mode! Token saved to resetToken variable.');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"jane@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/forgot-password",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"forgot-password"
							]
						},
						"description": "Initiates the forgot password flow. If the server is running with placeholder email settings, it will return `devToken` and `devResetUrl` inside the response body so you can test without opening a terminal window. This script captures it in `resetToken`."
					},
					"response": []
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"password\": \"newpassword123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/reset-password/{{resetToken}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"reset-password",
								"{{resetToken}}"
							]
						},
						"description": "Resets the user password. Replace `{{resetToken}}` with the token logged to the console or captured by the Forgot Password request."
					},
					"response": []
				}
			]
		},
		{
			"name": "Dashboard Profile (Protected)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [
						{
							"key": "token",
							"value": "{{authToken}}",
							"type": "string"
						}
					]
				},
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/profile",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"profile"
					]
				},
				"description": "Fetches the logged-in user profile. Requires a valid JWT bearer token. It reads the token automatically from `{{authToken}}` variable set during Login/Register."
			},
			"response": []
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000/api/auth",
			"type": "string"
		},
		{
			"key": "authToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "resetToken",
			"value": "",
			"type": "string"
		}
	]
}
