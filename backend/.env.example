PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/login-auth-db
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=1h

# Frontend URL (for password reset link)
FRONTEND_URL=http://localhost:5173

# Email Configurations for Nodemailer (Optional - falls back to logging to console if empty)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password_or_app_password
EMAIL_FROM=no-reply@authsystem.com
